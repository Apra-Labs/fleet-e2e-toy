{
  "name": "noteapi",
  "version": "1.0.0",
  "description": "REST API for managing notes with tags and search — demo project for Agentic AI Workshop (Advanced)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn src/index.ts",
    "pretest": "npm run build",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix"
  },
  "dependencies": {
    "express": "^4.21.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
