{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-destructive.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint:fix 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "browser-snapshot": {
      "command": "npx",
      "args": ["-y", "browser-snapshot-mcp-server"]
    }
  }
}
